# ── CHH Compliance Intelligence Center ─────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ── Authentication ──────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHH@Compliance2025!        # Change this before going live
JWT_SECRET_KEY=replace-with-random-64-char-string
JWT_EXPIRE_MINUTES=480                     # 8 hours

# ── Email Provider: choose sendgrid or mailgun ──────────────────────────────
EMAIL_PROVIDER=sendgrid

# SendGrid (https://app.sendgrid.com → Settings → API Keys)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx

# Mailgun (alternative — https://app.mailgun.com → Sending → Domains)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.chh.com.ng

# ── Sender / Recipients ──────────────────────────────────────────────────────
FROM_EMAIL=compliance@chh.com.ng
FROM_NAME=CHH Compliance Intelligence Center
ALWAYS_CC=cto@chh.com.ng                  # Segun is CC'd on everything

DEPT_FINANCE=cfo@chh.com.ng,finance.compliance@chh.com.ng
DEPT_UW=chief.underwriter@chi.com.ng
DEPT_IT=cto@chh.com.ng
DEPT_LEGAL=company.secretary@chh.com.ng,compliance@chh.com.ng
DEPT_CLAIMS=head.claims@chh.com.ng
DEPT_OPS=coo@chh.com.ng

# ── Database ─────────────────────────────────────────────────────────────────
DB_PATH=compliance.db
# For PostgreSQL on Render: uncomment and fill in
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── CORS (comma-separated allowed frontend origins) ──────────────────────────
ALLOWED_ORIGINS=https://chh-compliance.onrender.com,http://localhost:5173
